default: &default
  adapter: postgresql
  encoding: unicode
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>
  url: <%= ENV['DATABASE_URL'] %>

development:
  <<: *default
  database: big_message_development

test:
  <<: *default
  database: big_message_test

production:
  <<: *default
  database: big_message_production
