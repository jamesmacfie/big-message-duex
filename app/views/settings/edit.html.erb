<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Profile Settings
        </h3>
        <p class="mt-1 text-sm text-gray-500">
          Update your profile information and preferences.
        </p>

        <%= form_with model: @person, url: settings_path, class: "mt-6 space-y-6" do |f| %>
          <% if @person.errors.any? %>
            <div class="bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded">
              <ul>
                <% @person.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div>
            <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :name, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= f.label :description, "Bio", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_area :description, rows: 4, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
            <p class="mt-2 text-sm text-gray-500">Brief description for your profile.</p>
          </div>

          <div>
            <%= f.label :avatar, class: "block text-sm font-medium text-gray-700" %>
            <% if @person.avatar.attached? %>
              <div class="mt-2 flex items-center space-x-4">
                <%= image_tag @person.avatar, class: "h-16 w-16 rounded-full object-cover" %>
                <div class="text-sm text-gray-500">Current avatar</div>
              </div>
            <% end %>
            <div class="mt-2">
              <%= f.file_field :avatar, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            </div>
          </div>

          <div>
            <%= f.label :theme, class: "block text-sm font-medium text-gray-700" %>
            <%= f.select :theme, options_for_select([["Light", "light"], ["Dark", "dark"]], @person.theme), {}, class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md" %>
          </div>

          <div class="pt-5">
            <div class="flex justify-end space-x-3">
              <%= link_to "Cancel", root_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
              <%= f.submit "Save Changes", class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-6 bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">
          Account Information
        </h3>
        <div class="mt-4 space-y-3">
          <div>
            <span class="text-sm font-medium text-gray-500">Email:</span>
            <span class="ml-2 text-sm text-gray-900"><%= current_user.email %></span>
          </div>
          <div>
            <span class="text-sm font-medium text-gray-500">Account created:</span>
            <span class="ml-2 text-sm text-gray-900"><%= current_user.created_at.strftime("%B %d, %Y") %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
