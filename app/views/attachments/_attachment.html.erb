<div class="mt-2">
  <% if attachment.image? %>
    <!-- Image attachment -->
    <div class="max-w-sm">
      <% if attachment.file.attached? %>
        <%= image_tag attachment.file, class: "rounded-lg border border-gray-200 cursor-pointer hover:opacity-90 transition-opacity", data: { action: "click->lightbox#open" } %>
      <% end %>
    </div>
  <% elsif attachment.video? %>
    <!-- Video attachment -->
    <div class="max-w-md">
      <% if attachment.file.attached? %>
        <%= video_tag url_for(attachment.file), controls: true, class: "rounded-lg border border-gray-200 w-full" %>
      <% end %>
    </div>
  <% else %>
    <!-- Document attachment -->
    <div class="inline-flex items-center space-x-2 px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg hover:bg-gray-100 transition-colors">
      <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
      </svg>
      <div class="flex flex-col">
        <% if attachment.file.attached? %>
          <%= link_to attachment.file_name, rails_blob_path(attachment.file, disposition: "attachment"), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
          <span class="text-xs text-gray-500"><%= number_to_human_size(attachment.file_size) %></span>
        <% else %>
          <span class="text-sm font-medium text-gray-700"><%= attachment.file_name %></span>
          <span class="text-xs text-gray-500"><%= number_to_human_size(attachment.file_size) %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
