<% if message.has_replies? %>
  <div id="thread-indicator-<%= message.id %>" class="mt-2 flex items-center space-x-4">
    <div class="flex items-center space-x-3">
      <!-- Replier avatars -->
      <div class="flex -space-x-2">
        <% message.replier_people(limit: 3).each do |replier| %>
          <% if replier.avatar.attached? %>
            <%= image_tag replier.avatar,
                class: "inline-block h-6 w-6 rounded-full ring-2 ring-white object-cover",
                title: replier.name %>
          <% else %>
            <div class="inline-flex h-6 w-6 rounded-full bg-indigo-100 ring-2 ring-white items-center justify-center"
                 title="<%= replier.name %>">
              <span class="text-xs font-medium text-indigo-600"><%= replier.name[0].upcase %></span>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Reply count and snippet -->
      <button type="button"
              data-action="click->thread#open"
              data-message-id="<%= message.id %>"
              class="inline-flex flex-col items-start text-xs text-indigo-600 hover:text-indigo-700">
        <span class="font-medium flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          <%= pluralize(message.reply_count, 'reply') %>
        </span>
        <% if message.latest_reply_snippet %>
          <span class="text-gray-500 max-w-md truncate">
            <%= message.latest_reply_snippet %>
          </span>
        <% end %>
        <span class="text-gray-400">
          Last reply <%= time_ago_in_words(message.latest_reply.created_at) %> ago
        </span>
      </button>
    </div>
  </div>
<% end %>
