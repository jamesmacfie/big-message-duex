<div class="flex items-start space-x-3 group hover:bg-gray-50 -mx-4 px-4 py-2 rounded <%= reply.mentions?(current_user.person) ? 'bg-yellow-50 border-l-4 border-yellow-400 pl-3' : '' %>" id="message-<%= reply.id %>" data-message-id="<%= reply.id %>" data-controller="message-menu">
  <% if reply.person.avatar.attached? %>
    <%= image_tag reply.person.avatar, class: "h-8 w-8 rounded-full object-cover" %>
  <% else %>
    <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
      <span class="text-xs font-medium text-indigo-600"><%= reply.person.name[0].upcase %></span>
    </div>
  <% end %>
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline space-x-2">
      <p class="text-sm font-semibold text-gray-900"><%= reply.person.name %></p>
      <p class="text-xs text-gray-500"><%= reply.created_at.strftime("%l:%M %p") %></p>
      <% if reply.edited? %>
        <span class="text-xs text-gray-400">(edited)</span>
      <% end %>
    </div>

    <% if reply.deleted? %>
      <div class="mt-1 text-sm text-gray-400 italic">
        This message was deleted
      </div>
    <% else %>
      <% if reply.content.present? %>
        <div class="mt-1 text-sm text-gray-700 prose prose-sm max-w-none" id="message-content-<%= reply.id %>">
          <%= markdown(reply.content) %>
        </div>
      <% end %>

      <!-- Attachments -->
      <% if reply.attachments.any? %>
        <div class="mt-2 space-y-2">
          <%= render reply.attachments %>
        </div>
      <% end %>

      <!-- Edit form (hidden by default) -->
      <div class="hidden mt-1" id="message-edit-<%= reply.id %>" data-message-menu-target="editForm">
        <%= form_with model: reply, url: channel_message_path(reply.channel, reply), method: :patch, data: { turbo_frame: "_top", action: "turbo:submit-end->message-menu#cancelEdit" } do |f| %>
          <%= f.text_area :content, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm", rows: 3 %>
          <div class="mt-2 flex space-x-2">
            <%= f.submit "Save", class: "px-3 py-1 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700" %>
            <button type="button" data-action="click->message-menu#cancelEdit" class="px-3 py-1 bg-gray-200 text-gray-700 rounded text-sm hover:bg-gray-300">Cancel</button>
          </div>
        <% end %>
      </div>

      <!-- Reactions -->
      <%= render "messages/reactions", message: reply %>
    <% end %>
  </div>

  <!-- Message menu (only for message owner) -->
  <% unless reply.deleted? %>
    <% if reply.person == current_user.person %>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity">
        <div class="relative" data-message-menu-target="menuContainer">
          <button type="button" data-action="click->message-menu#toggleMenu" class="p-1 rounded hover:bg-gray-200">
            <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
            </svg>
          </button>
          <div class="hidden absolute right-0 mt-1 w-32 bg-white rounded-md shadow-lg border border-gray-200 z-10" data-message-menu-target="menu">
            <button type="button" data-action="click->message-menu#startEdit" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Edit</button>
            <%= button_to "Delete", channel_message_path(reply.channel, reply), method: :delete, data: { turbo_frame: "_top", turbo_confirm: "Are you sure?" }, class: "w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100" %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
