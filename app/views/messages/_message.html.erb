<div class="flex space-x-3 hover:bg-gray-50 -mx-4 px-4 py-2 rounded group" data-message-id="<%= message.id %>" id="message-<%= message.id %>">
  <div class="flex-shrink-0">
    <% if message.person.avatar.attached? %>
      <%= image_tag message.person.avatar, class: "h-10 w-10 rounded object-cover" %>
    <% else %>
      <div class="h-10 w-10 rounded bg-indigo-600 flex items-center justify-center">
        <span class="text-sm font-medium text-white"><%= message.person.name[0].upcase %></span>
      </div>
    <% end %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline space-x-2">
      <span class="font-semibold text-gray-900 text-sm"><%= message.person.name %></span>
      <span class="text-xs text-gray-500">
        <%= message.created_at.strftime("%l:%M %p") %>
      </span>
      <% if message.edited? %>
        <span class="text-xs text-gray-400">(edited)</span>
      <% end %>
    </div>
    <div class="mt-1 text-sm text-gray-900 whitespace-pre-wrap break-words">
      <%= message.content %>
    </div>

    <!-- Thread indicators and actions -->
    <% unless message.thread? %>
      <div class="mt-2 flex items-center space-x-4">
        <% if message.has_replies? %>
          <button type="button"
                  data-action="click->thread#open"
                  data-message-id="<%= message.id %>"
                  class="inline-flex items-center text-xs text-indigo-600 hover:text-indigo-700 font-medium">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            <%= pluralize(message.reply_count, 'reply') %>
            <% if message.latest_reply %>
              <span class="ml-2 text-gray-500">Last reply <%= time_ago_in_words(message.latest_reply.created_at) %> ago</span>
            <% end %>
          </button>
        <% else %>
          <button type="button"
                  data-action="click->thread#open"
                  data-message-id="<%= message.id %>"
                  class="text-xs text-gray-500 hover:text-indigo-600 opacity-0 group-hover:opacity-100 transition-opacity">
            Reply in thread
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
