<div class="flex space-x-3 hover:bg-gray-50 -mx-4 px-4 py-2 rounded group <%= message.mentions?(current_user.person) ? 'bg-yellow-50 border-l-4 border-yellow-400 pl-3' : '' %>" data-message-id="<%= message.id %>" id="message-<%= message.id %>" data-controller="message-menu">
  <div class="flex-shrink-0">
    <% if message.person.avatar.attached? %>
      <%= image_tag message.person.avatar, class: "h-10 w-10 rounded object-cover" %>
    <% else %>
      <div class="h-10 w-10 rounded bg-indigo-600 flex items-center justify-center">
        <span class="text-sm font-medium text-white"><%= message.person.name[0].upcase %></span>
      </div>
    <% end %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline space-x-2">
      <span class="font-semibold text-gray-900 text-sm"><%= message.person.name %></span>
      <span class="text-xs text-gray-500">
        <%= message.created_at.strftime("%l:%M %p") %>
      </span>
      <% if message.edited? %>
        <span class="text-xs text-gray-400">(edited)</span>
      <% end %>
    </div>

    <% if message.deleted? %>
      <div class="mt-1 text-sm text-gray-400 italic">
        This message was deleted
      </div>
    <% else %>
      <% if message.content.present? %>
        <div class="mt-1 text-sm text-gray-900 break-words prose prose-sm max-w-none" id="message-content-<%= message.id %>">
          <%= markdown(message.content) %>
        </div>
      <% end %>

      <!-- Attachments -->
      <% if message.attachments.any? %>
        <div class="mt-2 space-y-2">
          <%= render message.attachments %>
        </div>
      <% end %>

      <!-- Edit form (hidden by default) -->
      <div class="hidden mt-1" id="message-edit-<%= message.id %>" data-message-menu-target="editForm">
        <%= form_with model: message, url: channel_message_path(message.channel, message), method: :patch, data: { turbo_frame: "_top", action: "turbo:submit-end->message-menu#cancelEdit" } do |f| %>
          <%= f.text_area :content, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm", rows: 3 %>
          <div class="mt-2 flex space-x-2">
            <%= f.submit "Save", class: "px-3 py-1 bg-indigo-600 text-white rounded text-sm hover:bg-indigo-700" %>
            <button type="button" data-action="click->message-menu#cancelEdit" class="px-3 py-1 bg-gray-200 text-gray-700 rounded text-sm hover:bg-gray-300">Cancel</button>
          </div>
        <% end %>
      </div>

      <!-- Reactions -->
      <%= render "messages/reactions", message: message %>
    <% end %>

    <!-- Thread indicators and actions -->
    <% unless message.thread? %>
      <%= render "messages/thread_indicator", message: message %>
    <% end %>
  </div>

  <!-- Message menu (only for message owner) -->
  <% unless message.deleted? %>
    <% if message.person == current_user.person %>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity">
        <div class="relative" data-message-menu-target="menuContainer">
          <button type="button" data-action="click->message-menu#toggleMenu" class="p-1 rounded hover:bg-gray-200">
            <svg class="w-4 h-4 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
            </svg>
          </button>
          <div class="hidden absolute right-0 mt-1 w-32 bg-white rounded-md shadow-lg border border-gray-200 z-10" data-message-menu-target="menu">
            <button type="button" data-action="click->message-menu#startEdit" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Edit</button>
            <%= button_to "Delete", channel_message_path(message.channel, message), method: :delete, data: { turbo_frame: "_top", turbo_confirm: "Are you sure?" }, class: "w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100" %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
