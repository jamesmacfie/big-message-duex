<div class="flex h-screen bg-gray-100" data-controller="sidebar">
  <!-- Mobile backdrop -->
  <div data-sidebar-target="backdrop"
       data-action="click->sidebar#close"
       class="hidden fixed inset-0 bg-black bg-opacity-50 z-30 md:hidden">
  </div>

  <!-- Sidebar -->
  <div data-sidebar-target="sidebar"
       class="w-64 bg-indigo-900 text-white flex flex-col fixed md:relative inset-y-0 left-0 z-40 -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">
    <!-- Workspace header -->
    <div class="p-4 border-b border-indigo-800">
      <h1 class="text-xl font-bold">Big Message</h1>
      <p class="text-sm text-indigo-300"><%= current_user.person.name %></p>
    </div>

    <%= render "search/search_bar" %>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto">
      <!-- Favorites Section -->
      <div id="favorites-section">
        <%= render "channels/favorites_section", current_user: current_user, current_channel_id: @channel.id %>
      </div>

      <!-- Channels Section -->
      <div class="mt-4">
        <div class="px-4 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-indigo-300">Channels</h2>
          <div class="flex items-center space-x-2">
            <%= link_to browse_channels_path, class: "text-indigo-300 hover:text-white", title: "Browse channels" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            <% end %>
            <%= link_to new_channel_path, class: "text-indigo-300 hover:text-white", title: "Create channel" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
            <% end %>
          </div>
        </div>

        <div class="mt-2">
          <% current_user.person.accessible_channels.channels.active.includes(:members).order(:name).each do |channel| %>
            <% member = channel.members.find { |m| m.person_id == current_user.person.id } %>
            <% unread_count = member&.unread_count || 0 %>
            <%= link_to channel, class: "block px-4 py-2 hover:bg-indigo-800 transition-colors #{@channel.id == channel.id ? 'bg-indigo-800' : ''}" do %>
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <span class="text-gray-400 mr-2">#</span>
                  <span class="<%= unread_count > 0 ? 'font-bold' : '' %>"><%= channel.name %></span>
                </div>
                <% if unread_count > 0 %>
                  <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-600 rounded-full"><%= unread_count %></span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Direct Messages Section -->
      <div class="mt-6">
        <div class="px-4 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-indigo-300">Direct Messages</h2>
          <%= link_to new_dm_path, class: "text-indigo-300 hover:text-white", title: "New DM" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
          <% end %>
        </div>
        <div class="mt-2">
          <% dms = current_user.person.accessible_channels.dms.active.includes(:people, :members).order("channels.updated_at DESC") %>
          <% if dms.any? %>
            <% dms.each do |dm| %>
              <% member = dm.members.find { |m| m.person_id == current_user.person.id } %>
              <% unread_count = member&.unread_count || 0 %>
              <%= link_to dm, class: "block px-4 py-2 hover:bg-indigo-800 transition-colors #{@channel&.id == dm.id ? 'bg-indigo-800' : ''}" do %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center flex-1 min-w-0">
                    <% other_people = dm.people.where.not(id: current_user.person.id).limit(3) %>
                    <% if other_people.count > 1 %>
                      <!-- Group DM - show multiple avatars -->
                      <div class="flex -space-x-2 mr-2 flex-shrink-0">
                        <% other_people.each do |person| %>
                          <% if person.avatar.attached? %>
                            <%= image_tag person.avatar, class: "inline-block h-5 w-5 rounded-full ring-2 ring-indigo-900 object-cover" %>
                          <% else %>
                            <div class="inline-flex h-5 w-5 rounded-full bg-indigo-700 ring-2 ring-indigo-900 items-center justify-center">
                              <span class="text-xs font-medium"><%= person.name[0].upcase %></span>
                            </div>
                          <% end %>
                        <% end %>
                      </div>
                    <% else %>
                      <!-- 1-on-1 DM - single avatar -->
                      <% person = other_people.first %>
                      <% if person&.avatar&.attached? %>
                        <%= image_tag person.avatar, class: "h-5 w-5 rounded-full object-cover mr-2 flex-shrink-0" %>
                      <% else %>
                        <div class="h-5 w-5 rounded-full bg-indigo-700 flex items-center justify-center mr-2 flex-shrink-0">
                          <span class="text-xs font-medium"><%= dm.dm_name_for(current_user.person)[0].upcase %></span>
                        </div>
                      <% end %>
                    <% end %>
                    <span class="truncate <%= unread_count > 0 ? 'font-bold' : '' %>"><%= dm.dm_name_for(current_user.person) %></span>
                  </div>
                  <% if unread_count > 0 %>
                    <span class="inline-flex items-center justify-center px-2 py-0.5 text-xs font-bold leading-none text-white bg-red-600 rounded-full ml-2 flex-shrink-0"><%= unread_count %></span>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <p class="px-4 py-2 text-sm text-indigo-400">No direct messages yet</p>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Invite button -->
    <div class="px-4 pb-4">
      <%= link_to new_invite_path, class: "w-full inline-flex items-center justify-center px-4 py-2 border border-indigo-700 text-sm font-medium rounded-md text-indigo-200 bg-indigo-800 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
        </svg>
        Invite People
      <% end %>
    </div>

    <!-- User menu -->
    <div class="p-4 border-t border-indigo-800">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <% if current_user.person.avatar.attached? %>
            <%= image_tag current_user.person.avatar, class: "h-8 w-8 rounded-full object-cover" %>
          <% else %>
            <div class="h-8 w-8 rounded-full bg-indigo-700 flex items-center justify-center">
              <span class="text-sm font-medium"><%= current_user.person.name[0].upcase %></span>
            </div>
          <% end %>
          <span class="text-sm"><%= current_user.person.name %></span>
        </div>
        <div class="flex space-x-2">
          <%= link_to edit_settings_path, class: "text-indigo-300 hover:text-white" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          <% end %>
          <%= button_to logout_path, method: :delete, class: "text-indigo-300 hover:text-white" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Main content area -->
  <div class="flex-1 flex"
       data-controller="thread"
       data-thread-channel-id-value="<%= @channel.id %>">
    <div class="flex-1 flex flex-col"
         data-controller="messages"
         data-messages-channel-id-value="<%= @channel.id %>"
         data-messages-current-person-id-value="<%= current_user.person.id %>">
    <!-- Channel header -->
    <div class="bg-white border-b border-gray-200 px-4 py-2 md:px-6 md:py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-2 md:space-x-3 flex-1 min-w-0">
          <!-- Mobile hamburger menu -->
          <button type="button"
                  data-action="click->sidebar#toggle"
                  class="md:hidden text-gray-600 hover:text-gray-900 p-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
          <h2 class="text-lg md:text-xl font-bold text-gray-900 flex items-center truncate">
            <% if @channel.dm? %>
              <span class="text-gray-500 mr-2">@</span>
              <%= @channel.dm_name_for(current_user.person) %>
            <% else %>
              <span class="text-gray-500 mr-2">#</span>
              <%= @channel.name %>
            <% end %>
          </h2>
          <% if @channel.is_private %>
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          <% end %>
          <% if @current_member&.admin? %>
            <span class="hidden md:inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
              Admin
            </span>
          <% end %>
        </div>
        <div class="hidden md:flex items-center space-x-4">
          <%= link_to channel_members_path(@channel), class: "text-sm text-gray-500 hover:text-gray-700" do %>
            <%= pluralize(@channel.members.count, 'member') %>
          <% end %>

          <%= render "favorites/button", channel: @channel %>

          <% if @current_member&.admin? %>
            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="click->dropdown#toggle" class="text-gray-500 hover:text-gray-700">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"></path>
                </svg>
              </button>
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-10">
                <div class="py-1">
                  <%= link_to "Edit Channel", edit_channel_path(@channel), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= link_to "Manage Members", channel_members_path(@channel), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                  <%= button_to "Archive Channel", archive_channel_path(@channel), method: :post, class: "block w-full text-left px-4 py-2 text-sm text-red-700 hover:bg-gray-100", data: { turbo_confirm: "Are you sure you want to archive this channel?" } %>
                </div>
              </div>
            </div>
          <% else %>
            <%= button_to "Leave Channel", channel_member_path(@channel, @current_member), method: :delete, class: "text-sm text-red-600 hover:text-red-700", data: { turbo_confirm: "Are you sure you want to leave this channel?" } %>
          <% end %>
        </div>
      </div>
      <% if @channel.description.present? %>
        <p class="hidden md:block text-sm text-gray-600 mt-1"><%= @channel.description %></p>
      <% end %>
    </div>

    <!-- Messages area -->
    <div class="flex-1 overflow-y-auto px-4 py-3 md:px-6 md:py-4 bg-white">
      <% if @messages.empty? %>
        <div class="flex items-center justify-center h-full">
          <div class="text-center max-w-md">
            <div class="mb-4">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-indigo-100">
                <span class="text-2xl text-indigo-600">#</span>
              </div>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              Welcome to #<%= @channel.name %>
            </h3>
            <p class="text-gray-600 mb-4">
              <% if @channel.description.present? %>
                <%= @channel.description %>
              <% else %>
                This is the beginning of the #<%= @channel.name %> channel.
              <% end %>
            </p>
            <div class="text-sm text-gray-500">
              <p>Created by <%= @channel.created_by.name %> on <%= @channel.created_at.strftime("%B %d, %Y") %></p>
              <% if @channel.members.count > 1 %>
                <p class="mt-2">
                  Members:
                  <%= @channel.members.includes(:person).map { |m| m.person.name }.join(", ") %>
                </p>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <!-- Channel start message -->
        <div class="mb-8 pb-6 border-b border-gray-200">
          <div class="text-center max-w-md mx-auto">
            <div class="mb-3">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-indigo-100">
                <span class="text-xl text-indigo-600">#</span>
              </div>
            </div>
            <h3 class="text-base font-semibold text-gray-900 mb-1">
              Welcome to #<%= @channel.name %>
            </h3>
            <p class="text-sm text-gray-500">
              Created by <%= @channel.created_by.name %> on <%= @channel.created_at.strftime("%B %d, %Y") %>
            </p>
          </div>
        </div>

        <!-- Messages list -->
        <div id="messages" class="space-y-4" data-messages-target="container">
          <%= render partial: "messages/message", collection: @messages, as: :message, locals: { current_person: current_user.person } %>
        </div>
      <% end %>
    </div>

    <!-- Message input -->
    <%= render "channels/message_form", channel: @channel, message: @message, current_user: current_user %>
    </div>

    <!-- Thread panel (initially hidden, populated by Stimulus) -->
    <div id="thread-panel" class="hidden">
    </div>
  </div>
</div>
