<div class="bg-white border-t border-gray-200 px-6 py-4" id="message-form">
  <!-- Error message -->
  <% if local_assigns[:error] %>
    <div class="mb-3 px-4 py-3 rounded-md bg-red-50 border border-red-200">
      <p class="text-sm text-red-800"><%= error %></p>
    </div>
  <% end %>

  <!-- Typing indicator -->
  <div class="mb-2 px-1">
    <p class="text-sm text-gray-500 italic hidden" data-messages-target="typingIndicator"></p>
  </div>

  <div class="relative"
       data-controller="mention-autocomplete"
       data-mention-autocomplete-channel-id-value="<%= channel.id %>">
    <%= form_with model: [channel, message],
                  class: "flex flex-col space-y-2",
                  data: {
                    messages_target: "form",
                    action: "turbo:submit-end->messages#resetForm",
                    controller: "file-upload"
                  } do |f| %>
      <div class="flex items-start space-x-3">
        <div class="flex-1 relative">
          <%= f.text_area :content,
              rows: 1,
              placeholder: channel.dm? ? "Message #{channel.dm_name_for(current_user.person)}" : "Message ##{channel.name}",
              class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none",
              data: {
                messages_target: "input",
                mention_autocomplete_target: "input",
                action: "keydown->messages#handleKeydown keydown->mention-autocomplete#handleKeydown input->messages#handleInput input->mention-autocomplete#handleInput"
              } %>
          <!-- Autocomplete dropdown -->
          <div data-mention-autocomplete-target="dropdown"
               class="hidden absolute bottom-full left-0 mb-2 w-64 bg-white border border-gray-300 rounded-lg shadow-lg max-h-48 overflow-y-auto z-50">
          </div>
        </div>
        <div class="flex items-center space-x-2">
          <!-- File upload button -->
          <%= f.file_field :files,
              multiple: true,
              class: "hidden",
              id: "file-upload-input",
              data: {
                file_upload_target: "input",
                action: "change->file-upload#handleFiles"
              } %>
          <label for="file-upload-input" class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
            </svg>
          </label>
          <%= f.submit "Send", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
        </div>
      </div>
      <!-- File preview area -->
      <div data-file-upload-target="preview" class="hidden px-4 py-2 bg-gray-50 rounded-lg">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-gray-700">Attachments:</span>
          <button type="button"
                  data-action="click->file-upload#clearFiles"
                  class="text-sm text-red-600 hover:text-red-800">Clear all</button>
        </div>
        <div data-file-upload-target="list" class="space-y-1"></div>
      </div>
    <% end %>
  </div>
</div>
