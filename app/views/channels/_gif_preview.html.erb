<div class="bg-white border-t border-gray-200 px-6 py-4" id="message-form" data-controller="gif-preview">
  <div class="mb-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold text-gray-700">GIF Preview: "<%= query %>"</h3>
      <%= link_to "Cancel", channel_path(channel),
          data: { turbo_frame: "_top" },
          class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>

    <div class="bg-gray-50 rounded-lg p-4 mb-3">
      <div class="flex items-center justify-center bg-white rounded-lg overflow-hidden" style="max-height: 300px;">
        <% gifs.each_with_index do |gif, index| %>
          <img src="<%= gif[:preview_url] %>"
               alt="<%= gif[:title] %>"
               class="max-w-full max-h-full object-contain <%= index == 0 ? '' : 'hidden' %>"
               data-gif-preview-target="gif"
               data-gif-url="<%= gif[:url] %>"
               data-gif-title="<%= gif[:title] %>"
               data-query="<%= query %>">
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <button type="button"
              data-action="click->gif-preview#shuffle"
              class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        Shuffle
      </button>

      <%= form_with url: post_gif_channel_messages_path(channel), method: :post, data: { gif_preview_target: "form" } do |f| %>
        <%= f.hidden_field :gif_url, value: "", data: { gif_preview_target: "urlField" } %>
        <%= f.hidden_field :gif_title, value: "", data: { gif_preview_target: "titleField" } %>
        <%= f.hidden_field :query, value: query %>
        <%= f.submit "Send", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      <% end %>
    </div>
  </div>
</div>
