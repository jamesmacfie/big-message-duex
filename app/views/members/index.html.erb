<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">
            Manage Members
          </h1>
          <p class="mt-1 text-sm text-gray-600">
            Channel: <span class="font-medium">#<%= @channel.name %></span>
          </p>
        </div>
        <%= link_to "Back to Channel", @channel, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
      </div>
    </div>

    <% if @channel.admin?(current_user.person) %>
      <!-- Add Member Form -->
      <div class="bg-white shadow sm:rounded-lg mb-6">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
            Add Member
          </h3>
          <%= form_with url: channel_members_path(@channel), method: :post, class: "space-y-4" do |f| %>
            <div class="flex items-end space-x-3">
              <div class="flex-1">
                <%= label_tag :person_id, "Select a person", class: "block text-sm font-medium text-gray-700 mb-1" %>
                <%= select_tag :person_id,
                    options_from_collection_for_select(
                      Person.where.not(id: @channel.people.pluck(:id)).order(:name),
                      :id,
                      :name
                    ),
                    class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md",
                    include_blank: "Choose a person..." %>
              </div>
              <%= f.submit "Add Member", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none cursor-pointer" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Members List -->
    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
          Members (<%= @members.count %>)
        </h3>

        <div class="space-y-3">
          <% @members.each do |member| %>
            <div class="flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:bg-gray-50">
              <div class="flex items-center space-x-3">
                <% if member.person.avatar.attached? %>
                  <%= image_tag member.person.avatar, class: "h-10 w-10 rounded-full object-cover" %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                    <span class="text-sm font-medium text-indigo-600"><%= member.person.name[0].upcase %></span>
                  </div>
                <% end %>

                <div>
                  <div class="flex items-center space-x-2">
                    <p class="text-sm font-medium text-gray-900"><%= member.person.name %></p>
                    <% if member.admin? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
                        Admin
                      </span>
                    <% end %>
                    <% if member.person == @channel.created_by %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                        Creator
                      </span>
                    <% end %>
                  </div>
                  <% if member.person.user %>
                    <p class="text-xs text-gray-500"><%= member.person.user.email %></p>
                  <% end %>
                </div>
              </div>

              <% if @channel.admin?(current_user.person) && member.person != current_user.person %>
                <div class="flex items-center space-x-2">
                  <% if member.admin? %>
                    <%= button_to "Demote", channel_member_path(@channel, member, action_type: "demote"), method: :patch, class: "text-sm text-gray-600 hover:text-gray-800 px-3 py-1 border border-gray-300 rounded", data: { turbo_confirm: "Demote #{member.person.name} to regular member?" } %>
                  <% else %>
                    <%= button_to "Make Admin", channel_member_path(@channel, member, action_type: "promote"), method: :patch, class: "text-sm text-indigo-600 hover:text-indigo-800 px-3 py-1 border border-indigo-300 rounded", data: { turbo_confirm: "Make #{member.person.name} an admin?" } %>
                  <% end %>
                  <%= button_to "Remove", channel_member_path(@channel, member), method: :delete, class: "text-sm text-red-600 hover:text-red-800 px-3 py-1 border border-red-300 rounded", data: { turbo_confirm: "Remove #{member.person.name} from this channel?" } %>
                </div>
              <% elsif member.person == current_user.person %>
                <div class="text-sm text-gray-500">
                  You
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
