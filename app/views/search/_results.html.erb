<div class="max-h-96 overflow-y-auto">
  <% if results[:channels].any? || results[:dms].any? || results[:messages].any? %>
    <!-- Channels Results -->
    <% if results[:channels].any? %>
      <div class="px-3 py-2 text-xs font-semibold text-indigo-300 bg-indigo-950">
        Channels
      </div>
      <% results[:channels].each do |channel| %>
        <%= link_to channel_path(channel[:id]),
                    class: "block px-4 py-3 hover:bg-indigo-800 transition-colors border-b border-indigo-800",
                    data: { action: "click->search#selectResult" } do %>
          <div class="flex items-center">
            <span class="text-gray-400 mr-2">#</span>
            <div>
              <div class="font-medium"><%= channel[:name] %></div>
              <% if channel[:description].present? %>
                <div class="text-sm text-indigo-300 truncate"><%= channel[:description] %></div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <!-- DMs Results -->
    <% if results[:dms].any? %>
      <div class="px-3 py-2 text-xs font-semibold text-indigo-300 bg-indigo-950">
        Direct Messages
      </div>
      <% results[:dms].each do |dm| %>
        <%= link_to channel_path(dm[:id]),
                    class: "block px-4 py-3 hover:bg-indigo-800 transition-colors border-b border-indigo-800",
                    data: { action: "click->search#selectResult" } do %>
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <div>
              <div class="font-medium"><%= dm[:name] %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <!-- Messages Results -->
    <% if results[:messages].any? %>
      <div class="px-3 py-2 text-xs font-semibold text-indigo-300 bg-indigo-950">
        Messages
      </div>
      <% results[:messages].each do |message| %>
        <%= link_to channel_path(message[:channel_id]),
                    class: "block px-4 py-3 hover:bg-indigo-800 transition-colors border-b border-indigo-800",
                    data: { action: "click->search#selectResult" } do %>
          <div>
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium"><%= message[:person_name] %></span>
              <span class="text-xs text-indigo-400">in #<%= message[:channel_name] %></span>
            </div>
            <div class="mt-1 text-sm text-indigo-200 line-clamp-2">
              <%= sanitize message[:highlighted_content], tags: %w[mark], attributes: [] %>
            </div>
            <div class="mt-1 text-xs text-indigo-400">
              <%= time_ago_in_words(message[:created_at]) %> ago
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-4 py-8 text-center text-indigo-300">
      <svg class="mx-auto h-12 w-12 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <p class="mt-2">No results found for "<%= query %>"</p>
    </div>
  <% end %>
</div>
