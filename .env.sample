# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/big_message_development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=big_message_development

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# Rails Configuration
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_rails_secret
RAILS_ENV=development

# External API Keys
OPENAI_API_KEY=sk-your_openai_api_key_here
GIPHY_API_KEY=your_giphy_api_key_here

# Email Configuration (Development)
SMTP_ADDRESS=localhost
SMTP_PORT=1025
SMTP_DOMAIN=localhost
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@bigmessage.local

# Active Storage (Development uses local disk)
# For production, configure S3 or other cloud storage
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=big-message-uploads

# Action Cable
CABLE_ADAPTER=redis
CABLE_URL=redis://localhost:6379/1

# Application Settings
APP_HOST=localhost:3000
APP_PROTOCOL=http